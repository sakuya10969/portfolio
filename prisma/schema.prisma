generator client {
  provider = "prisma-client"
  output   = "../src/shared/lib/generated"
}

datasource db {
  provider = "postgresql"
}

enum SocialPlatform {
  github
  twitter
  linkedin
  website
  other
}

enum ProjectLinkType {
  github
  demo
  docs
  other
}

enum ExperienceType {
  work
  education
  activity
}

enum Proficiency {
  beginner
  intermediate
  advanced
  expert
}

model Profile {
  id          String       @id @default(uuid())
  name        String
  title       String
  bio         String
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  socialLinks SocialLink[]
}

model SocialLink {
  id        String         @id @default(uuid())
  profileId String
  platform  SocialPlatform
  url       String
  sortOrder Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProjectCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  sortOrder Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id           String              @id @default(uuid())
  slug         String              @unique
  title        String
  summary      String
  background   String
  architecture String
  highlights   String
  challenges   String
  futureWork   String?
  thumbnailUrl String?
  isPublished  Boolean             @default(false)
  sortOrder    Int
  categoryId   String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  category     ProjectCategory     @relation(fields: [categoryId], references: [id])
  links        ProjectLink[]
  technologies ProjectTechnology[]
}

model ProjectLink {
  id        String          @id @default(uuid())
  projectId String
  type      ProjectLinkType
  url       String
  label     String?
  sortOrder Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Technology {
  id          String              @id @default(uuid())
  name        String              @unique
  iconUrl     String?
  officialUrl String?
  sortOrder   Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  projects    ProjectTechnology[]
  skills      Skill[]
}

model ProjectTechnology {
  projectId    String
  technologyId String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id])

  @@id([projectId, technologyId])
}

model SkillCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  skills    Skill[]
}

model Skill {
  id           String        @id @default(uuid())
  name         String
  categoryId   String
  technologyId String?
  proficiency  Proficiency?
  sortOrder    Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  category     SkillCategory @relation(fields: [categoryId], references: [id])
  technology   Technology?   @relation(fields: [technologyId], references: [id])
}

model Experience {
  id           String         @id @default(uuid())
  type         ExperienceType
  organization String
  role         String
  description  String
  startDate    DateTime
  endDate      DateTime?
  sortOrder    Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
