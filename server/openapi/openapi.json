{
  "openapi": "3.0.0",
  "info": {
    "title": "Portfolio API",
    "version": "1.0.0",
    "description": "ポートフォリオサイトの API。Orval で型安全なクライアントを自動生成する。"
  },
  "components": {
    "schemas": {
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Profile"
          }
        },
        "required": [
          "data"
        ]
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "socialLinks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SocialLink"
            }
          }
        },
        "required": [
          "id",
          "name",
          "title",
          "bio",
          "avatarUrl",
          "socialLinks"
        ]
      },
      "SocialLink": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "profileId": {
            "type": "string"
          },
          "platform": {
            "$ref": "#/components/schemas/SocialPlatform"
          },
          "url": {
            "type": "string"
          },
          "sortOrder": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "profileId",
          "platform",
          "url",
          "sortOrder"
        ]
      },
      "SocialPlatform": {
        "type": "string",
        "enum": [
          "github",
          "twitter",
          "linkedin",
          "website",
          "other"
        ]
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiErrorDetail"
          }
        },
        "required": [
          "error"
        ]
      },
      "ApiErrorDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "入力内容に誤りがあります"
          },
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          }
        },
        "required": [
          "message",
          "code"
        ]
      },
      "CategoryListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectCategory"
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "ProjectCategory": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sortOrder": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "sortOrder"
        ]
      },
      "ProjectListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "background": {
            "type": "string"
          },
          "architecture": {
            "type": "string"
          },
          "highlights": {
            "type": "string"
          },
          "challenges": {
            "type": "string"
          },
          "futureWork": {
            "type": "string",
            "nullable": true
          },
          "thumbnailUrl": {
            "type": "string",
            "nullable": true
          },
          "isPublished": {
            "type": "boolean"
          },
          "sortOrder": {
            "type": "number"
          },
          "categoryId": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/ProjectCategory"
          },
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectLink"
            }
          },
          "technologies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Technology"
            }
          }
        },
        "required": [
          "id",
          "slug",
          "title",
          "summary",
          "background",
          "architecture",
          "highlights",
          "challenges",
          "futureWork",
          "thumbnailUrl",
          "isPublished",
          "sortOrder",
          "categoryId",
          "category",
          "links",
          "technologies"
        ]
      },
      "ProjectLink": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/ProjectLinkType"
          },
          "url": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "nullable": true
          },
          "sortOrder": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "projectId",
          "type",
          "url",
          "label",
          "sortOrder"
        ]
      },
      "ProjectLinkType": {
        "type": "string",
        "enum": [
          "github",
          "demo",
          "docs",
          "other"
        ]
      },
      "Technology": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "iconUrl": {
            "type": "string",
            "nullable": true
          },
          "officialUrl": {
            "type": "string",
            "nullable": true
          },
          "sortOrder": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name",
          "iconUrl",
          "officialUrl",
          "sortOrder"
        ]
      },
      "ProjectDetailResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Project"
          }
        },
        "required": [
          "data"
        ]
      },
      "SkillListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillCategoryWithSkills"
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "SkillCategoryWithSkills": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sortOrder": {
            "type": "number"
          },
          "skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Skill"
            }
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "sortOrder",
          "skills"
        ]
      },
      "Skill": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "categoryId": {
            "type": "string"
          },
          "technologyId": {
            "type": "string",
            "nullable": true
          },
          "proficiency": {
            "$ref": "#/components/schemas/Proficiency"
          },
          "sortOrder": {
            "type": "number"
          },
          "technology": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Technology"
              },
              {
                "nullable": true
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "categoryId",
          "technologyId",
          "proficiency",
          "sortOrder",
          "technology"
        ]
      },
      "Proficiency": {
        "type": "string",
        "nullable": true,
        "enum": [
          "beginner",
          "intermediate",
          "advanced",
          "expert",
          null
        ]
      },
      "ExperienceListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Experience"
            }
          }
        },
        "required": [
          "data"
        ]
      },
      "Experience": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/ExperienceType"
          },
          "organization": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string",
            "nullable": true
          },
          "sortOrder": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "type",
          "organization",
          "role",
          "description",
          "startDate",
          "endDate",
          "sortOrder"
        ]
      },
      "ExperienceType": {
        "type": "string",
        "enum": [
          "work",
          "education",
          "activity"
        ]
      },
      "ContactCreateResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "success": {
                "type": "boolean",
                "enum": [
                  true
                ]
              }
            },
            "required": [
              "success"
            ]
          }
        },
        "required": [
          "data"
        ]
      },
      "ContactRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "Sakuya"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "sakuya@example.com"
          },
          "subject": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "example": "ポートフォリオについて"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000,
            "example": "プロジェクトの詳細について相談したいです。"
          }
        },
        "required": [
          "name",
          "email",
          "subject",
          "message"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/profile": {
      "get": {
        "tags": [
          "Profile"
        ],
        "summary": "プロフィール取得",
        "responses": {
          "200": {
            "description": "プロフィール情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "404": {
            "description": "プロフィールが見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/projects/categories": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "カテゴリ一覧取得",
        "responses": {
          "200": {
            "description": "カテゴリ一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoryListResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/projects": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "プロジェクト一覧取得",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "カテゴリ slug でフィルタ"
            },
            "required": false,
            "description": "カテゴリ slug でフィルタ",
            "name": "category",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "技術名でフィルタ"
            },
            "required": false,
            "description": "技術名でフィルタ",
            "name": "technology",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "プロジェクト一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/projects/{slug}": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "プロジェクト詳細取得",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "プロジェクトの slug"
            },
            "required": true,
            "description": "プロジェクトの slug",
            "name": "slug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "プロジェクト詳細",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "プロジェクトが見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/skills": {
      "get": {
        "tags": [
          "Skills"
        ],
        "summary": "スキル一覧取得（カテゴリ別）",
        "responses": {
          "200": {
            "description": "スキル一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillListResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/experiences": {
      "get": {
        "tags": [
          "Experiences"
        ],
        "summary": "経歴一覧取得",
        "responses": {
          "200": {
            "description": "経歴一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExperienceListResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/contact": {
      "post": {
        "tags": [
          "Contact"
        ],
        "summary": "問い合わせを送信する",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "問い合わせを受け付けました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "入力内容に誤りがあります",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
